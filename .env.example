# Gemini API key (only used at embedding time; never stored in the DB)
GEMINI_API_KEY=

# Gemini Embedding 2 model id (multi-modal: text/image/audio/video/PDF)
LIFE_MEMORIZER_EMBED_MODEL=gemini-embedding-2

# Matryoshka (MRL) target dimension: Gemini Embedding 2 emits up to 3072; we
# downscale to 768 to optimize RAM and storage on edge hardware.
LIFE_MEMORIZER_EMBED_DIM=768

# Local Qdrant Edge storage path
LIFE_MEMORIZER_DB_PATH=./life_memorizer_db

# Collection name
LIFE_MEMORIZER_COLLECTION=life_moments

# Quantization: none | scalar | binary
LIFE_MEMORIZER_QUANTIZATION=scalar

# Time-to-live for moments in days (0 disables TTL)
LIFE_MEMORIZER_TTL_DAYS=90

# Automatically prune on a cadence (1 to enable) and how often (hours)
LIFE_MEMORIZER_AUTO_PRUNE=0
LIFE_MEMORIZER_AUTO_PRUNE_INTERVAL_HOURS=24

# Summarize expired moments into digests before deletion (1) vs. drop them (0)
LIFE_MEMORIZER_SUMMARIZE_ON_PRUNE=1

# Privacy: persist the media file path (1) or omit it entirely (0)
LIFE_MEMORIZER_STORE_MEDIA_PATH=1

# --- Local RAG (answer generation) ---
# Backend: ollama (fully local Gemma) | gemini (Gemma via google-genai)
LIFE_MEMORIZER_RAG_BACKEND=ollama
LIFE_MEMORIZER_RAG_MODEL=gemma2:2b
LIFE_MEMORIZER_OLLAMA_HOST=http://localhost:11434
LIFE_MEMORIZER_RAG_CONTEXT_SIZE=5
# Set to 1 for a deterministic offline answer generator (no model needed)
LIFE_MEMORIZER_FAKE_RAG=0

# Frame sampling rate (frames per second) during ingest
LIFE_MEMORIZER_FPS=1.0

# Set to 1 to use a deterministic offline stub embedder (no API calls)
LIFE_MEMORIZER_FAKE_EMBEDDINGS=0
